### Anamnesis Endpoints Test
### Base URL: http://localhost:8000/api

### Variables
@baseUrl = http://localhost:8000/api
@authToken = your_auth_token_here
@patientId = 1
@caregiverId = 1

### List all anamnesis
GET {{baseUrl}}/anamnesis/
Authorization: Bearer {{authToken}}

###

### Create anamnesis
POST {{baseUrl}}/anamnesis/
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "patient": {{patientId}},
    "caregiver": {{caregiverId}},
    "main_diagnosis": "Transtorno do Espectro Autista",
    "associated_conditions": "TDAH, Ansiedade",
    "responsible_contact": "Maria Silva - (11) 99999-0000",
    "reference_professional": "Dra. Ana - Fonoaudióloga",
    "cognitive_level": "Moderado",
    "attention_duration": "10-15 minutos",
    "memory_profile": "Melhor memória visual",
    "learning_pace": "Normal",
    "language_style": "Literal",
    "auditory_comprehension": "Compreende frases simples",
    "functional_speech": "Sim, parcial",
    "speech_intelligibility": "Pouco inteligível",
    "uses_gestures": true,
    "uses_signs": false,
    "uses_images_or_symbols": true,
    "preferred_symbol_systems": "Arasaac, Fotografias",
    "symbol_comprehension": "Muitos",
    "communication_priorities": "Expressar necessidades, socializar"
}

###

### Get specific anamnesis
GET {{baseUrl}}/anamnesis/1/
Authorization: Bearer {{authToken}}

###

### Update anamnesis
PUT {{baseUrl}}/anamnesis/1/
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "patient": {{patientId}},
    "caregiver": {{caregiverId}},
    "main_diagnosis": "Transtorno do Espectro Autista - Nível 2",
    "associated_conditions": "TDAH, Ansiedade social",
    "responsible_contact": "Maria Silva - (11) 99999-0000",
    "reference_professional": "Dra. Ana - Fonoaudióloga",
    "cognitive_level": "Moderado",
    "attention_duration": "15 minutos",
    "memory_profile": "Boa memória visual",
    "learning_pace": "Normal",
    "language_style": "Literal",
    "auditory_comprehension": "Compreende frases e comandos simples",
    "functional_speech": "Sim, parcial",
    "speech_intelligibility": "Moderadamente inteligível",
    "uses_gestures": true,
    "uses_signs": false,
    "uses_images_or_symbols": true,
    "preferred_symbol_systems": "Arasaac, Fotografias, Desenhos",
    "symbol_comprehension": "Muitos",
    "communication_priorities": "Expressar necessidades, fazer escolhas, socializar"
}

###

### List anamnesis by caregiver
GET {{baseUrl}}/caregivers/{{caregiverId}}/anamnesis/
Authorization: Bearer {{authToken}}

###

### List anamnesis for patient
GET {{baseUrl}}/patients/{{patientId}}/anamnesis/
Authorization: Bearer {{authToken}}

###

### Create anamnesis for specific patient
POST {{baseUrl}}/patients/{{patientId}}/anamnesis/create/
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "caregiver": {{caregiverId}},
    "main_diagnosis": "Síndrome de Down",
    "associated_conditions": "Cardiopatia congênita",
    "responsible_contact": "Ana Souza - (11) 98888-0000",
    "reference_professional": "Terapeuta Ocupacional Carla",
    "cognitive_level": "Boa",
    "attention_duration": "15-20 minutos",
    "memory_profile": "Boa memória visual e auditiva",
    "learning_pace": "Normal",
    "language_style": "Literal",
    "auditory_comprehension": "Compreende bem",
    "functional_speech": "Sim, parcial",
    "speech_intelligibility": "Moderadamente inteligível",
    "uses_gestures": true,
    "uses_signs": true,
    "uses_images_or_symbols": true,
    "preferred_symbol_systems": "Fotografias, PCS",
    "symbol_comprehension": "Muitos",
    "communication_priorities": "Comunicação funcional, socialização"
}

###

### Get specific anamnesis by patient and caregiver
GET {{baseUrl}}/patients/{{patientId}}/anamnesis/caregiver/{{caregiverId}}/
Authorization: Bearer {{authToken}}

###

### Get anamnesis by IDs (alternative method)
GET {{baseUrl}}/anamnesis/get/?patient_id={{patientId}}&caregiver_id={{caregiverId}}
Authorization: Bearer {{authToken}}

###

### Delete anamnesis (soft delete)
DELETE {{baseUrl}}/anamnesis/1/
Authorization: Bearer {{authToken}}
